{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "target": "ES6",
    "jsx": "react",
    "sourceMap": true,
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "importHelpers": true,
    "lib": ["es2018", "dom"]
  },
  "include": ["./src/**/*"]
}
